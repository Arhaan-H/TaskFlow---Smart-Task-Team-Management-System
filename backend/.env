# ============================================================
# TaskFlow Backend - Environment Variables
# ============================================================
# This file stores sensitive configuration values that should
# NEVER be committed to version control (add .env to .gitignore)
# ============================================================

# The port the Express server will listen on
PORT=5000

# MongoDB connection string (local development database)
MONGO_URI=mongodb://localhost:27017/taskflow

# Secret key used to sign JSON Web Tokens — keep this long and random in production!
JWT_SECRET=taskflow_super_secret_jwt_key_2024

# How long a JWT stays valid before the user must log in again
JWT_EXPIRES_IN=7d

# Tells the app which environment it is running in
# Values: development | production | test
NODE_ENV=development
