# ============================================================
# TaskFlow Backend - Environment Variables EXAMPLE
# ============================================================
# Copy this file to .env and fill in your actual values.
# This file IS safe to commit — it contains no real secrets.
# ============================================================

# The port the Express server will listen on
PORT=5000

# MongoDB Atlas connection string (replace with your credentials)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/taskflow

# A long, random secret string for signing JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# How long a JWT stays valid (7d = 7 days, 1h = 1 hour, etc.)
JWT_EXPIRES_IN=7d

# Environment mode — change to "production" when deploying
NODE_ENV=development
